/*
 * ═══════════════════════════════════════════════════════════════════════════
 *  CircleGuard — Jenkinsfile.dev
 *
 *  Target branches : develop, feature/*
 *  Jenkins job "Script Path": jenkins/Jenkinsfile.dev
 *
 *  Stages:
 *    1. Checkout
 *    2. Build Docker Images  (parallel, 6 services)
 *    3. Unit Tests           (parallel, --continue)
 *    4. Deploy DEV           (kubectl apply → circleguard-dev)
 *    5. Smoke Test DEV       (/actuator/health body check via port-forward + curl)
 *
 *  Required Jenkins credentials  (Manage Jenkins → Credentials → Global):
 *   ID                    Type                Purpose
 *   ─────────────────     ──────────────────  ─────────────────────────────
 *   kubeconfig-file       Secret file         kubeconfig for K8s cluster
 *
 *  Required Jenkins plugins:
 *   pipeline-model-definition  workflow-scm-step  git
 *   credentials-binding        junit              ws-cleanup
 *   kubernetes-cli             (for withKubeConfig)
 * ═══════════════════════════════════════════════════════════════════════════
 */

pipeline {
    agent any

    environment {
        DOCKER_BUILDKIT = '1'
        IMAGE_PREFIX    = 'circleguard'
        IMAGE_TAG       = "${BUILD_NUMBER}"
        K8S_NS_DEV      = 'circleguard-dev'
        KUBECTL         = 'kubectl --insecure-skip-tls-verify'
    }

    stages {

        // ─────────────────────────────────────────────────────────────────
        // STAGE 1 — CHECKOUT
        // ─────────────────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                sh 'git fetch --tags || true'
            }
            post {
                failure { echo 'Stage 1 (Checkout) failed — check SCM configuration and credentials.' }
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // STAGE 2 — BUILD DOCKER IMAGES (parallel, 6 services)
        //
        // Build context is always the repo root so multi-module Dockerfiles
        // can copy from sibling services. DOCKER_BUILDKIT=1 enables layer
        // caching. Each image is tagged :BUILD_NUMBER (immutable) and :latest.
        // ─────────────────────────────────────────────────────────────────
        stage('Build Docker Images') {
            parallel {

                stage('auth-service') {
                    steps {
                        sh """
                            docker build \\
                                -f services/circleguard-auth-service/Dockerfile \\
                                -t ${IMAGE_PREFIX}/circleguard-auth-service:${IMAGE_TAG} \\
                                -t ${IMAGE_PREFIX}/circleguard-auth-service:latest \\
                                .
                        """
                    }
                    post {
                        failure { echo 'Stage 2 (Build) failed: circleguard-auth-service — check Dockerfile and build context.' }
                    }
                }

                stage('identity-service') {
                    steps {
                        sh """
                            docker build \\
                                -f services/circleguard-identity-service/Dockerfile \\
                                -t ${IMAGE_PREFIX}/circleguard-identity-service:${IMAGE_TAG} \\
                                -t ${IMAGE_PREFIX}/circleguard-identity-service:latest \\
                                .
                        """
                    }
                    post {
                        failure { echo 'Stage 2 (Build) failed: circleguard-identity-service.' }
                    }
                }

                stage('form-service') {
                    steps {
                        sh """
                            docker build \\
                                -f services/circleguard-form-service/Dockerfile \\
                                -t ${IMAGE_PREFIX}/circleguard-form-service:${IMAGE_TAG} \\
                                -t ${IMAGE_PREFIX}/circleguard-form-service:latest \\
                                .
                        """
                    }
                    post {
                        failure { echo 'Stage 2 (Build) failed: circleguard-form-service.' }
                    }
                }

                stage('promotion-service') {
                    steps {
                        sh """
                            docker build \\
                                -f services/circleguard-promotion-service/Dockerfile \\
                                -t ${IMAGE_PREFIX}/circleguard-promotion-service:${IMAGE_TAG} \\
                                -t ${IMAGE_PREFIX}/circleguard-promotion-service:latest \\
                                .
                        """
                    }
                    post {
                        failure { echo 'Stage 2 (Build) failed: circleguard-promotion-service.' }
                    }
                }

                stage('notification-service') {
                    steps {
                        sh """
                            docker build \\
                                -f services/circleguard-notification-service/Dockerfile \\
                                -t ${IMAGE_PREFIX}/circleguard-notification-service:${IMAGE_TAG} \\
                                -t ${IMAGE_PREFIX}/circleguard-notification-service:latest \\
                                .
                        """
                    }
                    post {
                        failure { echo 'Stage 2 (Build) failed: circleguard-notification-service.' }
                    }
                }

                stage('dashboard-service') {
                    steps {
                        sh """
                            docker build \\
                                -f services/circleguard-dashboard-service/Dockerfile \\
                                -t ${IMAGE_PREFIX}/circleguard-dashboard-service:${IMAGE_TAG} \\
                                -t ${IMAGE_PREFIX}/circleguard-dashboard-service:latest \\
                                .
                        """
                    }
                    post {
                        failure { echo 'Stage 2 (Build) failed: circleguard-dashboard-service.' }
                    }
                }

            }
        }

        // ─────────────────────────────────────────────────────────────────
        // STAGE 3 — UNIT TESTS (parallel Gradle workers, --continue)
        //
        // --continue collects failures from all modules before stopping so
        // every test report is archived in a single run.
        // ─────────────────────────────────────────────────────────────────
        stage('Unit Tests') {
            steps {
                sh """
                    ./gradlew \\
                        :services:circleguard-auth-service:test \\
                        :services:circleguard-identity-service:test \\
                        :services:circleguard-form-service:test \\
                        :services:circleguard-promotion-service:test \\
                        :services:circleguard-notification-service:test \\
                        :services:circleguard-dashboard-service:test \\
                        --no-daemon \\
                        --parallel \\
                        --continue
                """
            }
            post {
                always {
                    junit allowEmptyResults: false,
                          testResults: '**/build/test-results/test/*.xml'
                }
                failure { echo 'Stage 3 (Unit Tests) failed — review JUnit report in Jenkins for failing test classes.' }
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // STAGE 4 — DEPLOY DEV
        //
        // All kubectl calls wrapped in withKubeConfig so the credential is
        // scoped to this stage only. ${KUBECTL} carries --insecure-skip-tls-verify
        // to bypass TLS verification when running inside Jenkins-in-Docker.
        //
        // Order:
        //   1. Idempotent namespace creation via dry-run pipe.
        //   2. Apply infra (postgres, redis, neo4j, kafka, openldap, mailhog).
        //   3. Wait for each infra deployment with rollout status --timeout=120s.
        //   4. Apply 6 application services.
        //   5. Wait for each app rollout (fail-fast: no || true).
        // ─────────────────────────────────────────────────────────────────
        stage('Deploy DEV') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-file',
                                serverUrl:     'https://kubernetes.docker.internal:6443']) {
                    script {

                        sh """
                            ${KUBECTL} create namespace ${K8S_NS_DEV} \\
                                --dry-run=client -o yaml | ${KUBECTL} apply --validate=false -f -
                        """

                        sh """
                            ${KUBECTL} apply --validate=false -f k8s/postgres.yml  -n ${K8S_NS_DEV}
                            ${KUBECTL} apply --validate=false -f k8s/redis.yml     -n ${K8S_NS_DEV}
                            ${KUBECTL} apply --validate=false -f k8s/neo4j.yml     -n ${K8S_NS_DEV}
                            ${KUBECTL} apply --validate=false -f k8s/kafka.yml     -n ${K8S_NS_DEV}
                            ${KUBECTL} apply --validate=false -f k8s/openldap.yml  -n ${K8S_NS_DEV}
                            ${KUBECTL} apply --validate=false -f k8s/mailhog.yml   -n ${K8S_NS_DEV}
                        """

                        sh """
                            ${KUBECTL} rollout status deployment/postgres -n ${K8S_NS_DEV} --timeout=120s || true
                            ${KUBECTL} rollout status deployment/redis    -n ${K8S_NS_DEV} --timeout=120s || true
                            ${KUBECTL} rollout status deployment/neo4j    -n ${K8S_NS_DEV} --timeout=120s || true
                            ${KUBECTL} rollout status deployment/kafka    -n ${K8S_NS_DEV} --timeout=120s || true
                        """

                        sh """
                            ${KUBECTL} apply --validate=false -f k8s/auth-service.yml         -n ${K8S_NS_DEV}
                            ${KUBECTL} apply --validate=false -f k8s/identity-service.yml     -n ${K8S_NS_DEV}
                            ${KUBECTL} apply --validate=false -f k8s/form-service.yml         -n ${K8S_NS_DEV}
                            ${KUBECTL} apply --validate=false -f k8s/promotion-service.yml    -n ${K8S_NS_DEV}
                            ${KUBECTL} apply --validate=false -f k8s/notification-service.yml -n ${K8S_NS_DEV}
                            ${KUBECTL} apply --validate=false -f k8s/dashboard-service.yml    -n ${K8S_NS_DEV}
                        """

                        sh """
                            ${KUBECTL} rollout status deployment/circleguard-auth-service         -n ${K8S_NS_DEV} --timeout=120s
                            ${KUBECTL} rollout status deployment/circleguard-identity-service     -n ${K8S_NS_DEV} --timeout=120s
                            ${KUBECTL} rollout status deployment/circleguard-form-service         -n ${K8S_NS_DEV} --timeout=120s
                            ${KUBECTL} rollout status deployment/circleguard-promotion-service    -n ${K8S_NS_DEV} --timeout=300s
                            ${KUBECTL} rollout status deployment/circleguard-notification-service -n ${K8S_NS_DEV} --timeout=120s
                            ${KUBECTL} rollout status deployment/circleguard-dashboard-service    -n ${K8S_NS_DEV} --timeout=120s
                        """
                    }
                }
            }
            post {
                failure { echo 'Stage 4 (Deploy DEV) failed — inspect: kubectl get events -n circleguard-dev --sort-by=.lastTimestamp' }
            }
        }

        stage('Smoke Test DEV') {
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-file', serverUrl: 'https://kubernetes.docker.internal:6443']) {
                    script {
                        sleep(30)
                        def services = ['circleguard-auth-service', 'circleguard-identity-service', 'circleguard-form-service', 'circleguard-promotion-service', 'circleguard-notification-service', 'circleguard-dashboard-service']
                        services.each { svc ->
                            def status = sh(returnStdout: true, script: "${KUBECTL} get pods -n ${K8S_NS_DEV} -l app=${svc} --field-selector=status.phase=Running --no-headers | wc -l").trim()
                            if (status.toInteger() < 1) {
                                error("Smoke test FAILED — ${svc} has no Running pods")
                            }
                            echo "SMOKE OK  ${svc} → ${status} pod(s) Running"
                        }
                    }
                }
            }
            post {
                failure { echo "Stage 5 (Smoke Test DEV) failed — one or more services have no Running pods." }
            }
        }

    }

    post {
        success {
            echo "DEV build #${env.IMAGE_TAG} deployed and smoke-tested in namespace '${env.K8S_NS_DEV}'."
        }
        failure {
            script {
                echo "DEV build #${env.IMAGE_TAG} FAILED on branch '${env.BRANCH_NAME}'."
                withKubeConfig([credentialsId: 'kubeconfig-file',
                                serverUrl:     'https://kubernetes.docker.internal:6443']) {
                    sh "${env.KUBECTL} get pods -n ${env.K8S_NS_DEV} 2>/dev/null | grep -vE '(Running|Completed|Terminating)' || true"
                }
            }
        }
        always {
            sh 'docker image prune -f || true'
            withKubeConfig([credentialsId: 'kubeconfig-file',
                            serverUrl:     'https://kubernetes.docker.internal:6443']) {
                sh "${env.KUBECTL} delete namespace ${env.K8S_NS_DEV} --ignore-not-found=true || true"
            }
            cleanWs()
        }
    }
}
